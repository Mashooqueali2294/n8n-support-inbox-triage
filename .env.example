# ── n8n Configuration ───────────────────────────────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# Basic auth (set to true in production)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# ── Application Variables (used in workflow expressions) ─
# Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Email address for notifications and daily summary
NOTIFY_EMAIL=your-email@gmail.com

# ── Optional: ngrok for public webhook URL ───────────────
# WEBHOOK_URL=https://your-ngrok-url.ngrok.io
